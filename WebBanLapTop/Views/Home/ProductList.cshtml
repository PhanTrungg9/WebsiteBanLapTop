@model IEnumerable<WebBanLapTop.Models.vv_ProductList>
@{
    var groupdProducts = (Model != null && Model.Any())
       ? Model.GroupBy(p => p.category_id)
              .Select(g => new
              {
                  CategoryId = g.Key,
                  CategoryName = g.First().category_name,
                  Products = g.ToList()
              }).ToList()
       : null;
}
<body>
    <div class="container">
        <div class="section pt-5">
            @if (groupdProducts != null && groupdProducts.Any())
            {
                foreach (var category in groupdProducts)
                {
                    <div class="section-header">
                        <a href="">
                            @category.CategoryName
                        </a>
                    </div>

                    <div class="filter-tabs">
                        <span class="filter-label">Mức giá:</span>
                        <a href="" class="filter-tab">5 TRIỆU - 10 TRIỆU</a>
                        <a href="" class="filter-tab">15 TRIỆU - 20 TRIỆU</a>
                        <a href="" class="filter-tab">25 TRIỆU - 30 TRIỆU</a>
                        <a href="" class="filter-tab">TRÊN 40 TRIỆU</a>
                    </div>

                    <div class="products-slider">
                        @foreach (var product in category.Products)
                        {
                            <div class="product-card">

                                @if (product.amount.HasValue && product.amount.Value > 0)
                                {
                                    <div class="discount-badges">
                                        @if (product.start_date < DateTime.Now && product.end_date > DateTime.Now)
                                        {
                                            <div class="discount-badge">
                                                @if (product.is_fixed == true)
                                                {
                                                    <text>-@(((product.amount.Value / product.price.Value) * 100).ToString("0.00"))%</text>
                                                }
                                                else
                                                {
                                                    <text>-@product.amount.Value %</text>
                                                }

                                            </div>
                                        }
                                        else
                                        {
                                            <span class="product_amount_empty"></span>
                                        }

                                    </div>
                                }

                                <a href="@Url.Action("Detail", "Product", new { id = product.product_id })">
                                    <img src="@(string.IsNullOrEmpty(product.image) ? "/images/no-image.jpg" : product.image.StartsWith("/") ? product.image : "/images/products/" + product.image)"
                                         alt="@product.product_name"
                                         class="product-image" />
                                </a>
                                <h3 class="product-name">
                                    <a href="#">
                                        @product.product_name
                                    </a>
                                </h3>
                                <div class="product-description">
                                    <a href="@Url.Action("Detail", "Product", new { id = product.product_id })">
                                        @product.description
                                    </a>
                                </div>
                                <div class="product-quantity">
                                    @if (product.quantity > 0)
                                    {
                                        <div class="in-stock ">Còn hàng: <span class="count-quantity">@product.quantity</span> </div>
                                    }
                                    else
                                    {
                                        <span class="out-of-stock">Hết hàng</span>

                                    }
                                </div>
                                <div class="product_dates">
                                    @if (product.start_date < DateTime.Now && product.end_date > DateTime.Now)
                                    {

                                        <span class="date-label">
                                            <i class="far fa-calendar-alt"></i>
                                            @product.start_date.Value.ToString("dd/MM/yyyy") - @product.end_date.Value.ToString("dd/MM/yyyy")
                                        </span>

                                    }
                                    else
                                    {
                                        <span class="product_date_empty">Chưa có đợt giảm giá</span>
                                    }
                                </div>
                                <div class="product-price">
                                    @if (product.start_date < DateTime.Now && product.end_date > DateTime.Now)
                                    {
                                        decimal discountPrice = 0;
                                        if (product.is_fixed == true)
                                        {
                                            discountPrice = (decimal)product.price - (decimal)product.amount;
                                        }
                                        else
                                        {
                                            discountPrice = (decimal)product.price * (1 - (decimal)product.amount / 100);
                                        }
                                        <div class="discount">
                                            <span class="original-price" style="text-decoration: line-through; color:blue">@product.price.Value.ToString("N0") đ</span>
                                            <span class="discount-price">@discountPrice.ToString("N0") đ</span>
                                            <span class="save-amount">Tiết kiệm @((product.price.Value - discountPrice).ToString("N0")) đ</span>
                                        </div>

                                    }
                                    else
                                    {
                                        <span class="current-price">@product.price.Value.ToString("N0") đ</span>
                                    }
                                </div>

                                <div class="product-btn">
                                    <a data-id="@product.product_id" class="btn custom-btn btnadd">Mua Ngay</a>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="no-products">
                    <p>Không có sản phẩm nào để hiển thị.</p>
                    <p>Model: @(Model == null ? "null" : $"{Model.Count()} items")</p>
                </div>
            }
        </div>
    </div>
</body>
<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css" />
<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css" />
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

/*    body {
        font-family: Arial, sans-serif;
        background-color: #f5f5f5;
        padding: 20px;
    }

    .container {
        max-width: 1140px;
        margin: 0 auto;
    }*/

    .section {
        margin-bottom: 40px;
    }

    .section-header {
        background: linear-gradient(135deg, #4169E1 0%, #5B8CFF 100%);
        padding: 15px 30px;
        font-size: 24px;
        font-weight: bold;
        display: inline-block;
        position: relative;
        margin-bottom: 20px;
    }

        .section-header a {
            color: white;
            text-decoration: none;
        }

        .section-header::after {
            content: '';
            position: absolute;
            right: -20px;
            top: 0;
            width: 0;
            height: 0;
            border-left: 20px solid #5B8CFF;
            border-top: 27px solid transparent;
            border-bottom: 27px solid transparent;
        }

    .product-btn {
        width: 90%;
        max-width: 400px;
        position: absolute;
        bottom: 20px;
        left: 5%;
        /*        margin: 20px auto;*/
    }

        .product-btn a {
            display: block;
            width: 100%;
            padding: 14px 24px;
            color: #2a83e9;
            text-align: center;
            text-decoration: none;
            font-size: 15px;
            font-weight: 600;
            border-radius: 8px;
            background: rgba(241,248,254,1);
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .product-btn a:hover {
                background: #2a83e9;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(42, 131, 233, 0.3);
            }

    .filter-tabs {
        display: flex;
        gap: 15px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-label {
        font-weight: bold;
        color: #333;
    }

    .filter-tab {
        padding: 8px 16px;
        background-color: white;
        border: 1px solid #ddd;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s;
        color: #4169E1;
        text-decoration: none;
        font-size: 14px;
    }

        .filter-tab:hover {
            background-color: #4169E1;
            color: white;
            border-color: #4169E1;
        }

    .products-slider {
        margin: 0 -10px;
    }

    .product-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        position: relative;
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
        margin: 0 10px;
        display: flex;
        flex-direction: column;
        height: 560px;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

            .product-card:hover .product-image {
                transform: scale(1.05);
            }

    .discount-badge {
        position: absolute;
        right: 5px;
        background-color: #e74c3c;
        color: white;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 16px;
        z-index: 1;
    }

    .product-image {
        width: 100%;
        height: 200px;
        object-fit: contain;
        margin-bottom: 15px;
    }

    .product-name {
        margin: 15px 0 10px;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.4;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

        .product-name a {
            color: #333;
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .product-name a:hover {
                color: #007bff;
            }

    .product_dates {
        background-color: #f8f9fa;
        padding: 8px 12px;
        border-radius: 6px;
        margin-bottom: 5px;
        font-size: 12px;
        color: #555;
        text-align: center;
    }

    .product-date i {
        margin-right: 5px;
        color: #007bff;
    }



    .product-price {
        margin-bottom: 15px;
        padding: 10px 0;
        position: absolute;
        bottom: 60px;
        width: 100%;
    }

    .discount {
        border-top: 1px solid #eee;
        border-bottom: 1px solid #eee;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .original-price {
        font-size: 14px;
        color: #999 !important;
        text-decoration: line-through;
    }

    .current-price {
        position: relative;
        top: -30px;
    }

    .discount-price, .current-price {
        font-size: 20px;
        font-weight: bold;
        color: #e74c3c;
    }

    .save-amount {
        font-size: 12px;
        color: #27ae60;
        font-weight: 600;
    }

    .product-description {
        margin-bottom: 10px;
        margin-bottom: 10px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        color: #666;
    }

        .product-description a {
            color: #666;
            font-weight: 500;
            text-decoration: none;
        }

    .slick-prev,
    .slick-next {
        width: 40px;
        height: 40px;
        z-index: 1;
    }

    .slick-prev {
        left: -50px;
    }

    .slick-next {
        right: -50px;
    }

        .slick-prev:before,
        .slick-next:before {
            font-size: 40px;
            color: #4169E1;
        }

    .slick-dots {
        bottom: -35px;
    }

        .slick-dots li button:before {
            font-size: 12px;
            color: #4169E1;
        }

        .slick-dots li.slick-active button:before {
            color: #4169E1;
        }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>
<script>
    $(document).ready(function () {
        $('.products-slider').slick({
            slidesToShow: 4,
            slidesToScroll: 1,
            infinite: false,
            arrows: true,
            dots: true,
            responsive: [
                {
                    breakpoint: 1024,
                    settings: {
                        slidesToShow: 3,
                        slidesToScroll: 1
                    }
                },
                {
                    breakpoint: 768,
                    settings: {
                        slidesToShow: 2,
                        slidesToScroll: 1
                    }
                },
                {
                    breakpoint: 480,
                    settings: {
                        slidesToShow: 1,
                        slidesToScroll: 1
                    }
                }
            ]
        });
        $('.btnadd').on('click', function () {
            var btn = $(this);
            var productId = $(this).data('id');
            console.log('Product ID:', productId);
            $.ajax({
                url: '/Home/Add',
                type: 'POST',
                data: { id: productId },
                dataType: 'json',
                success: function (response) {
                    console.log('Response:', response);
                    if (response.success) {
                        alert(response.message);
                        $('.cart-count').text(response.totalItems)
                        btn.closest('.product-card').find('.count-quantity').text(response.quantityproduct)

                    } else {
                        if (response.requireLogin) {
                            if (confirm(response.message + ' Bạn có muốn chuyển đến trang đăng nhập?')) {
                                window.location.href = '/Account/Login';
                            }
                        }
                        else {
                            alert(response.message);
                        }
                    }
                },
                error: function () {
                    alert('Đã xảy ra lỗi khi thêm sản phẩm vào giỏ hàng.');
                }
            });

        });
    });
</script>