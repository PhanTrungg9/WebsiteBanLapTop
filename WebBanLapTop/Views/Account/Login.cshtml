@{
    ViewBag.Title = "Log in";
}
<link rel="stylesheet" type="text/css" href="~/Content/assets/styles/main_styles.css">
<div class="container" style="margin-top:160px">
    <hr />
    <h2>@ViewBag.Title.</h2>
    <div class="row">
        <div class="col-md-8">
            <h4>Đăng nhập vào tài khoản của bạn</h4>
            <hr />
            <form id="form-login" class="form-horizontal">
                @Html.AntiForgeryToken()

                <!--begin::Body-->
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-10 mb-3">
                            <label for="UserName" class="form-label">Tên đăng nhập</label>
                            <input type="text" class="form-control" id="txt_user" name="txt_user" required />
                        </div>

                        <div class="col-lg-10 mb-3">
                            <label for="Password" class="form-label">Mật khẩu</label>
                            <input type="password" class="form-control" id="txt_pass" name="txt_pass" required />
                        </div>

                        <div class="col-lg-10">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" id="RememberMe" name="RememberMe" value="true" />
                                    Remember Me
                                </label>
                            </div>
                        </div>

                        <div id="loginMessage" class="col-lg-10 mt-3"></div>

                        <div class="col-lg-10">
                            <button type="button" id="btn_login" class="btn btn-info">Đăng nhập</button>
                        </div>

                        <div class="col-lg-10 mt-3">
                            <p style="display:flex;justify-content:space-between">
                                <a href="/Account/Register">Đăng ký tài khoản mới</a>
                                <a href="#">Quên mật khẩu?</a>
                            </p>
                        </div>
                        <div class="col-lg-10">
                            <p style="display:flex;justify-content:space-between">
                                <a href="/Admin/Account/Login">Bạn là quản trị viên</a>
                            </p>
                        </div>
                    </div>
                </div>
                <!--end::Body-->
            </form>
        </div>
        <div class="col-md-4">
            <h4>Welcome to COLOSHOP</h4>
            <hr />
            <h5 class="text-muted ">Trang web chuyên cung cấp các dòng laptop chất lượng, giá tốt và dịch vụ tận tâm. Hãy đăng nhập để bắt đầu trải nghiệm mua sắm của bạn ngay hôm nay!</h5>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    console.log("Script loaded!");
    console.log("Button exists:", $("#btn_login").length);
    $("#btn_login").click(function () {
        console.log("Button clicked!");
        var form = $('#form-login')[0];
        var formData = new FormData(form);

        $.ajax({
            type: "POST",
            url: window.location.origin + '/Account/Sign_In',
            data: formData,
            processData: false,
            contentType: false,
            cache: false,
            success: function (response) {
                if (response.success) {
                    alert(response.message);
                    window.location.href = response.redirectUrl;
                } else {
                    alert(response.message);
                }
            },
            error: function (xhr, status, error) {
                alert("Có lỗi xảy ra: " + error);
                console.log(xhr.responseText);
            }
        });
    });
</script>
