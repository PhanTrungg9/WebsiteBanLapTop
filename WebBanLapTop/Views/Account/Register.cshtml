
@{
    ViewBag.Title = "Register";
}
<link rel="stylesheet" type="text/css" href="~/Content/assets/styles/main_styles.css">
<div class="container" style="margin-top:160px">
    <div class="row">
        <div class="col-md-12">
            <h2>@ViewBag.Title.</h2>
            <h4>Create a new account</h4>
            <hr />
        <form id="registerForm" class="form-horizontal">
            <!--begin::Body-->
            <div class="card-body">

                <div class="row">
                    <div class="col-lg-5 mb-2">
                        <label for="full_name" class="form-label">Họ Tên</label>
                        <input type="text" class="form-control" id="full_name" name="full_name" />
                    </div>
                    <div class="col-lg-5 mb-2">
                        <label for="address" class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" id="address" name="address" />
                    </div>

                    <div class="col-lg-5 mb-2">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" />
                    </div>
                    <div class="col-lg-5 mb-2">
                        <label for="phone" class="form-label">Số điện thoại</label>
                        <input type="text" class="form-control" id="phone" name="phone" />
                    </div>

                    <div class="col-lg-10 mb-2">
                        <label for="user_name" class="form-label">Tên tài khoản</label>
                        <input type="text" class="form-control" id="user_name" name="user_name" />
                    </div>
                    <div class="col-lg-5 mb-2">
                        <label for="password" class="form-label">Mật khẩu</label>
                        <input type="password" class="form-control" id="password" name="password" />
                    </div>

                    <div class="col-lg-5 mb-2">
                        <label for="confirmPassword" class="form-label">Xác nhận mật khẩu</label>
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" />
                    </div>
                    <div id="registerMessage" class="mt-3"></div>
                    <div class="col-md-offset-2 col-md-10">
                        <button type="button" id="btn_register" class="btn btn-info">Đăng kí</button>
                    </div>
                </div>
            </div>
            <!--end::Body-->
            <!--begin::Footer-->
            <!--end::Footer-->
        </form>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $("#btn_register").click(function () {
        var form = $('#registerForm')[0];
        var formData = new FormData(form);
        $.ajax({
            type: "POST",
            data: formData,
            url: window.location.origin + '/Account/In_Register',   // API xử lý
            //data: formData,                                 // Dữ liệu form
            processData: false,                             // Không xử lý data thành query string
            contentType: false,                             // Không tự động set Content-Type
            cache: false,                                   // Không cache
            success: function (response) {
                alert(response);
                console.log("Ajax success:", response);
                if (response.toLowerCase().includes("thành công")) {
                    window.location.href = "/Account/Login";
                }
            },
            error: function (data) {
                console.log(data);
            }
        });
    });
</script>