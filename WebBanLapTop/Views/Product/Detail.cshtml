@section scripts{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        $(document).ready(function () {

            // Thumbnail Click
            $('.thumbnail').on('click', function () {
                $('.thumbnail').removeClass('active');
                $(this).addClass('active');

                var newImage = $(this).data('image');
                $('#mainProductImage').attr('src', newImage);
            });

            // Quantity Controls
            $('#btnPlus').on('click', function () {
                var input = $('#quantityInput');
                var currentVal = parseInt(input.val());
                var maxVal = parseInt(input.attr('max'));

                if (currentVal < maxVal) {
                    input.val(currentVal + 1);
                }
            });

            $('#btnMinus').on('click', function () {
                var input = $('#quantityInput');
                var currentVal = parseInt(input.val());
                var minVal = parseInt(input.attr('min'));

                if (currentVal > minVal) {
                    input.val(currentVal - 1);
                }
            });



            // Add to Cart - Main Product
            $('#btnAddToCart').on('click', function () {
                var productId = $(this).data('id');
                var quantity = parseInt($('#quantityInput').val());

                $.ajax({
                    url: '/Home/Add',
                    type: 'POST',
                    data: {
                        id: productId,
                        quantity: quantity
                    },
                    dataType: 'json',
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            $('.cart-count').text(response.totalItems);
                        } else {
                            if (response.requireLogin) {
                                if (confirm(response.message + ' Bạn có muốn chuyển đến trang đăng nhập?')) {
                                    window.location.href = '/Account/Login';
                                }
                            } else {
                                alert(response.message);
                            }
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra khi thêm sản phẩm vào giỏ hàng!');
                    }
                });
            });

            // Add to Cart - Related Products
            $('.btnadd').on('click', function () {
                var productId = $(this).data('id');
                var quantity = 1;

                $.ajax({
                    url: '/Home/Add',
                    type: 'POST',
                    data: {
                        id: productId,
                        quantity: quantity
                    },
                    dataType: 'json',
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            $('.cart-count').text(response.totalItems);
                        } else {
                            if (response.requireLogin) {
                                if (confirm(response.message + ' Bạn có muốn chuyển đến trang đăng nhập?')) {
                                    window.location.href = '/Account/Login';
                                }
                            } else {
                                alert(response.message);
                            }
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra khi thêm sản phẩm vào giỏ hàng!');
                    }
                });
            });

            // Prevent quantity input manual change
            $('#quantityInput').on('keydown paste', function (e) {
                e.preventDefault();
                return false;
            });

            // Image zoom on hover (optional enhancement)
            $('#mainProductImage').on('mouseenter', function () {
                $(this).css({
                    'transform': 'scale(1.05)',
                    'transition': 'transform 0.3s ease'
                });
            }).on('mouseleave', function () {
                $(this).css('transform', 'scale(1)');
            });

            // Smooth scroll to reviews
            $('.reviews-section').on('click', function () {
                $('html, body').animate({
                    scrollTop: $(this).offset().top - 20
                }, 500);
            });

        });
    </script>
}