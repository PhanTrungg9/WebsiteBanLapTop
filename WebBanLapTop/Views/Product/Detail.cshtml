@model WebBanLapTop.Models.vw_ProductDetail
@{
    ViewBag.Title = Model.product_name;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var images = ViewBag.ProductImages as List<WebBanLapTop.Models.vw_ProductImage> ?? new List<WebBanLapTop.Models.vw_ProductImage>();
    var reviews = ViewBag.Reviews as List<WebBanLapTop.Models.vw_ProductReview> ?? new List<WebBanLapTop.Models.vw_ProductReview>();
    var relatedProducts = ViewBag.RelatedProducts as List<WebBanLapTop.Models.vw_CategoryProductList> ?? new List<WebBanLapTop.Models.vw_CategoryProductList>();
}

<div class="product-detail-container">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="@Url.Action("Index", "Home")">
            <i class="fas fa-home"></i> Home
        </a>
        <span class="separator">/</span>
        <a href="@Url.Action("ProductCategory", "Product", new { categoryId = Model.category_id })">
            @Model.category_name
        </a>
        <span class="separator">/</span>
        <span class="current">@Model.product_name</span>
    </div>

    <!-- Main Product Section -->
    <div class="product-main-section">

        <!-- Left: Image Gallery -->
        <div class="product-gallery">

            <!-- Thumbnail List -->
            <div class="thumbnail-list">
                <!-- Main Image as first thumbnail -->
                <div class="thumbnail active" data-image="@(string.IsNullOrEmpty(Model.main_image) ? "/images/no-image.jpg" : (Model.main_image.StartsWith("/") ? Model.main_image : "/images/products/" + Model.main_image))">
                    <img src="@(string.IsNullOrEmpty(Model.main_image) ? "/images/no-image.jpg" : (Model.main_image.StartsWith("/") ? Model.main_image : "/images/products/" + Model.main_image))"
                         alt="@Model.product_name" />
                </div>

                @if (images.Any())
                {
                    foreach (var img in images)
                    {
                        <div class="thumbnail" data-image="@(string.IsNullOrEmpty(img.image) ? "/images/no-image.jpg" : (img.image.StartsWith("/") ? img.image : "/images/products/" + img.image))">
                            <img src="@(string.IsNullOrEmpty(img.image) ? "/images/no-image.jpg" : (img.image.StartsWith("/") ? img.image : "/images/products/" + img.image))"
                                 alt="@Model.product_name" />
                        </div>
                    }
                }
            </div>

            <!-- Main Image Display -->
            <div class="main-image-display">
                <img id="mainProductImage"
                     src="@(string.IsNullOrEmpty(Model.main_image) ? "/images/no-image.jpg" : (Model.main_image.StartsWith("/") ? Model.main_image : "/images/products/" + Model.main_image))"
                     alt="@Model.product_name" />

                @if (Model.has_active_discount == 1)
                {
                    <div class="discount-badge">
                        -@Model.discount_percentage.Value.ToString("0")%
                    </div>
                }
            </div>
        </div>

        <!-- Right: Product Info -->
        <div class="product-info-section">

            <h1 class="product-title">@Model.product_name</h1>

            <p class="product-description">
                @(string.IsNullOrEmpty(Model.description) ? "Nam tempus turpis at metus scelerisque placerat nulla deumantos solicitud felis. Pellentesque diam dolor, elementum etos lobortis des mollis ut..." : Model.description)
            </p>

            <!-- Free Delivery Badge -->
            <div class="delivery-badge">
                <i class="fas fa-shipping-fast"></i>
                <span>FREE DELIVERY</span>
            </div>

            <!-- Price Section -->
            <div class="price-section">
                @if (Model.has_active_discount == 1)
                {
                    <div class="price-with-discount">
                        <span class="original-price">@Model.price.Value.ToString("N0") đ</span>
                        <span class="current-price">@Model.final_price.Value.ToString("N0") đ</span>
                    </div>
                }
                else
                {
                    <span class="current-price">@Model.price.Value.ToString("N0") đ</span>
                }


            </div>



            <!-- Stock Status -->
            <div class="stock-status">
                @if (Model.quantity > 0)
                {
                    <span class="in-stock">
                        <i class="fas fa-check-circle"></i>
                        Sẵn hàng
                    </span>
                }
                else
                {
                    <span class="out-of-stock">
                        <i class="fas fa-times-circle"></i>
                        Hết hàng
                    </span>
                }
            </div>

            <!-- Quantity & Actions -->
            <div class="quantity-actions">
                <div class="quantity-selector">
                    <label>Số lượng:</label>
                    <div class="quantity-controls">
                        <button class="qty-btn minus" id="btnMinus">
                            <i class="fas fa-minus"></i>
                        </button>
                        <input type="number" id="quantityInput" value="1" min="1" max="@Model.quantity" readonly />
                        <button class="qty-btn plus" id="btnPlus">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>

                <button class="btn-add-to-cart" id="btnAddToCart" data-id="@Model.product_id">
                    <i class="fas fa-shopping-cart"></i>
                    Thêm vào giỏ hàng
                </button>


            </div>

            <!-- Additional Info -->
            <div class="additional-info">
                <div class="info-item">
                    <i class="fas fa-building"></i>
                    <strong>Brand:</strong> @(Model.brand_name ?? "N/A")
                </div>
                <div class="info-item">
                    <i class="fas fa-tag"></i>
                    <strong>Category:</strong> @(Model.category_name ?? "N/A")
                </div>
            </div>

        </div>
    </div>

    <!-- Reviews Section -->
    @*@if (reviews.Any())
        {
            <div class="reviews-section">
                <h2 class="section-title">
                    <i class="fas fa-comments"></i> Customer Reviews (@reviews.Count)
                </h2>
                <div class="reviews-list">
                    @foreach (var review in reviews)
                    {
                        <div class="review-item">
                            <div class="review-header">
                                <div class="review-avatar">
                                    <i class="fas fa-user-circle"></i>
                                </div>
                                <div class="review-meta">
                                    <strong>@review.user_name</strong>
                                    <span class="review-date">@review.created_at.Value.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                            <p class="review-comment">@review.comment</p>
                        </div>
                    }
                </div>
            </div>
        }*@

    <!-- Related Products Section -->
    <div class="related-products-section">
        <h2 class="section-title">
            <i class="fas fa-layer-group"></i> Sản phẩm tương tự
        </h2>

        @if (relatedProducts != null && relatedProducts.Any())
        {
            <div class="related-products-grid">
                @foreach (var rp in relatedProducts)
                {
                    <div class="related-product-card">

                        @if (rp.has_active_discount == 1 && rp.amount.HasValue)
                        {
                            <div class="discount-badge-small">
                                @if (rp.is_fixed == true)
                                {
                                    @("-" + ((rp.amount.Value / rp.price.Value) * 100).ToString("0") + "%")
                                }
                                else
                                {
                                    @("-" + rp.amount.Value + "%")
                                }
                            </div>
                        }

                        <a href="@Url.Action("Detail","Product",new { id = rp.product_id })">
                            <div class="related-product-image">
                                <img src="@(string.IsNullOrEmpty(rp.image) ? "/images/no-image.jpg" : (rp.image.StartsWith("/") ? rp.image : "/images/products/" + rp.image))"
                                     alt="@rp.product_name" />
                            </div>
                        </a>

                        <div class="related-product-info">
                            <h3 class="related-product-name">
                                <a href="@Url.Action("Detail","Product",new { id = rp.product_id })">
                                    @rp.product_name
                                </a>
                            </h3>

                            <div class="related-product-brand">
                                <i class="fas fa-building"></i> @(rp.brand_name ?? "N/A")
                            </div>

                            <div class="related-product-price">
                                @if (rp.has_active_discount == 1)
                                {
                                    <span class="related-original-price">@rp.price.Value.ToString("N0") đ</span>
                                    <span class="related-current-price">@rp.final_price.Value.ToString("N0") đ</span>
                                }
                                else
                                {
                                    <span class="related-current-price">@rp.price.Value.ToString("N0") đ</span>
                                }
                            </div>

                            <button class="btn-add-cart-small btnadd" data-id="@rp.product_id">
                                <i class="fas fa-shopping-cart"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-related-products">
                <p>Không có sản phẩm tương tự.</p>
            </div>
        }
    </div>


</div>

