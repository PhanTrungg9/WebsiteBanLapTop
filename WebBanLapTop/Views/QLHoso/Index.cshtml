@model WebBanLapTop.Models.tb_user
@{
    ViewBag.Title = "Hồ Sơ Cá Nhân";
}

<style>
    .profile-container {
        max-width: 650px;
        margin: 40px auto;
        background: #ffffff;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
    }

    .profile-title {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 20px;
        text-align: center;
        color: #2c3e50;
    }

    .profile-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .profile-table th {
            background: #f7f9fc;
            width: 180px;
            padding: 12px;
            font-weight: 600;
            color: #34495e;
            border-bottom: 1px solid #e0e6ed;
        }

        .profile-table td {
            padding: 12px;
            border-bottom: 1px solid #e0e6ed;
            color: #2c3e50;
        }

    /* Highlight khi đang chỉnh sửa */
    .edit-mode {
        background-color: #e8f7ff !important;
        transition: 0.2s;
    }

    #btnEdit, #btnSave {
        width: 130px;
        padding: 10px 0;
        border-radius: 8px;
        font-weight: 600;
    }

        #btnEdit:disabled {
            background: #b9b9b9 !important;
            cursor: not-allowed;
        }
</style>


<div class="profile-container">

    <div class="profile-title">Thông Tin Tài Khoản</div>

    <table class="profile-table">
        <tbody>
            <tr>
                <th>Họ tên</th>
                <td id="val_full_name">@Model.full_name</td>
            </tr>
            <tr>
                <th>Email</th>
                <td id="val_email">@Model.email</td>
            </tr>
            <tr>
                <th>SĐT</th>
                <td id="val_phone">@Model.phone</td>
            </tr>
            <tr>
                <th>Mật khẩu</th>
                <td id="val_password">@Model.password</td>
            </tr>
            <tr>
                <th>Địa chỉ</th>
                <td id="val_address">@Model.address</td>
            </tr>
        </tbody>
    </table>

    <div class="mt-3">
        <button id="btnEdit" class="btn btn-warning">Chỉnh sửa</button>
        <button id="btnSave" class="btn btn-primary ml-2" style="display:none;">Xác nhận</button>
    </div>

    <input type="hidden" id="user_id" value="@Model.user_id" />

</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    // Nút chỉnh sửa
    $("#btnEdit").click(function () {

        // Khóa nút chỉnh sửa
        $("#btnEdit").attr("disabled", true);

        let full = $("#val_full_name").text().trim();
        let email = $("#val_email").text().trim();
        let phone = $("#val_phone").text().trim();
        let pass = $("#val_password").text().trim();
        let addr = $("#val_address").text().trim();

        $("#val_full_name").html(`<input id="edit_full_name" class="form-control edit-mode" value="${full}"/>`);
        $("#val_email").html(`<input id="edit_email" class="form-control edit-mode" value="${email}"/>`);
        $("#val_phone").html(`<input id="edit_phone" class="form-control edit-mode" value="${phone}"/>`);
        $("#val_password").html(`<input id="edit_password" class="form-control edit-mode" value="${pass}"/>`);
        $("#val_address").html(`<input id="edit_address" class="form-control edit-mode" value="${addr}"/>`);

        $("#btnSave").show();
    });

    // Nút xác nhận
    $("#btnSave").click(function () {

        $.ajax({
            url: '/QLHoso/Update',
            type: 'POST',
            data: {
                user_id: $("#user_id").val(),
                full_name: $("#edit_full_name").val(),
                email: $("#edit_email").val(),
                phone: $("#edit_phone").val(),
                password: $("#edit_password").val(),
                address: $("#edit_address").val()
            },
            success: function (res) {
                if (res.success) {

                    $("#val_full_name").text(res.data.full_name);
                    $("#val_email").text(res.data.email);
                    $("#val_phone").text(res.data.phone);
                    $("#val_password").text(res.data.password);
                    $("#val_address").text(res.data.address);

                    alert("Cập nhật thành công!");

                    // Ẩn nút xác nhận
                    $("#btnSave").hide();

                    // Mở lại nút edit
                    $("#btnEdit").attr("disabled", false);
                }
                else {
                    alert(res.message);
                }
            },
            error: function () {
                alert("Lỗi server!");
            }
        });
    });
    // Load lịch sử mua hàng
    function loadOrderHistory() {
        $.ajax({
            url: '/QLHoso/GetOrderHistory',
            type: 'GET',
            success: function (res) {
                if (res.success) {
                    let rows = "";
                    let index = 1;

                    res.data.forEach(o => {
                        rows += `
                        <tr>
                            <td>${index++}</td>
                            <td>${o.order_id}</td>
                            <td>${formatDate(o.order_date_str)}</td>
                            <td>${o.status}</td>
                            <td> <a href=" /QLHoso/Xemchitiet/${o.order_id}"
                                   class="btn btn-info btn-sm">Xem chi tiết</a>
                            </td>
                        </tr>
                    `;
                    });

                    $("#orderHistoryTable tbody").html(rows);
                }
            }
        });
    }

    // Hàm format ngày
    function formatDate(dateString) {
        if (!dateString) return "—";

        const parts = dateString.split("-");
        if (parts.length !== 3) return "—";

        const [year, month, day] = parts;

        return `${day}/${month}/${year}`;
    }

    // Gọi load khi vào trang
    $(document).ready(function () {
        loadOrderHistory();
    });
    function viewDetails(orderId) {
        $.ajax({
            url: '/QLHoso/GetOrderDetails',
            type: 'GET',
            data: { orderId },
            success: function (res) {
                if (res.success) {
                    let rows = "";
                    res.data.forEach(p => {
                        rows += `
                        <div class="detail-item">
                            <img src="${p.image}" class="detail-img" />
                            <span class="detail-name">${p.product_name}</span>
                            <span class="detail-qty">x${p.quantity}</span>
                        </div>
                        <hr/>
                    `;
                    });

                    $("#detailList").html(rows);
                    $("#detailTotal").text(res.total.toLocaleString("vi-VN") + " đ");

                    $("#detailModal").fadeIn(200);
                }
            }
        });
    }

    function closeDetail() {
        $("#detailModal").fadeOut(150);
    }


</script>

<h2 style="margin-top: 20px; text-align: center;">Lịch sử mua hàng</h2>

<table id="orderHistoryTable" class="profile-table">
    <thead>
        <tr>
            <th>STT</th>
            <th>Mã đơn hàng</th>
            <th>Ngày giờ</th>
            <th>Trạng thái</th>
            <th>Cụ thể</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<style>

    #orderHistoryTable th,
    #orderHistoryTable td {
        text-align: center;
        vertical-align: middle;
    }

    /* optional: make it look nicer */
    #orderHistoryTable {
        width: 100%;
        border-collapse: collapse;
        margin-top: 12px;
    }

        #orderHistoryTable th {
            background: #2c3e50;
            color: #fff;
            padding: 10px;
        }

        #orderHistoryTable td {
            padding: 10px;
            border: 1px solid #e6e6e6;
        }

        #orderHistoryTable tbody tr:nth-child(even) {
            background: #fafafa;
        }
</style>


