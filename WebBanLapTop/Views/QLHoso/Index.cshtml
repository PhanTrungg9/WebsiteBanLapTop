@model WebBanLapTop.Models.tb_user
@{
    ViewBag.Title = "Hồ Sơ Cá Nhân";

}

<style>
    .profile-container {
        max-width: 700px;
        margin: 40px auto;
        background: #ffffff;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
    }

    /* Thanh tab */
    .profile-tabs {
        display: flex;
        border-bottom: 2px solid #ddd;
        margin-bottom: 20px;
    }

    .profile-tab {
        flex: 1;
        padding: 12px;
        text-align: center;
        cursor: pointer;
        font-weight: 600;
        color: #34495e;
        border-radius: 8px 8px 0 0;
    }

    .tab-active {
        background: #2c3e50;
        color: #fff;
    }

    /* Bảng thông tin */
    .profile-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .profile-table th {
            background: #f7f9fc;
            width: 180px;
            padding: 12px;
            font-weight: 600;
            color: #34495e;
            border-bottom: 1px solid #e0e6ed;
        }

        .profile-table td {
            padding: 12px;
            border-bottom: 1px solid #e0e6ed;
            color: #2c3e50;
        }

    .edit-mode {
        background-color: #e8f7ff !important;
        transition: 0.2s;
    }

    #btnEdit, #btnSave {
        width: 130px;
        padding: 10px 0;
        border-radius: 8px;
        font-weight: 600;
    }

    /* Bảo mật */
    .security-box input {
        margin-bottom: 12px;
    }

    /* Lịch sử mua hàng */
    #orderHistoryTable th,
    #orderHistoryTable td {
        text-align: center;
        vertical-align: middle;
    }

    #orderHistoryTable {
        width: 100%;
        border-collapse: collapse;
        margin-top: 12px;
    }

        #orderHistoryTable th {
            background: #2c3e50;
            color: #fff;
            padding: 10px;
        }

        #orderHistoryTable td {
            padding: 10px;
            border: 1px solid #e6e6e6;
        }

        #orderHistoryTable tbody tr:nth-child(even) {
            background: #fafafa;
        }
</style>


<div class="profile-container">

    <!-- TAB -->
    <div class="profile-tabs">
        <div id="tabAccount" class="profile-tab tab-active">Thông tin tài khoản</div>
        <div id="tabSecurity" class="profile-tab">Bảo mật</div>
    </div>


    <!-- =============================== -->
    <!-- TAB 1 – THÔNG TIN TÀI KHOẢN -->
    <!-- =============================== -->
    <div id="contentAccount">

        <table class="profile-table">
            <tbody>
                <tr>
                    <th>Họ tên</th>
                    <td id="val_full_name">@Model.full_name</td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td id="val_email">@Model.email</td>
                </tr>
                <tr>
                    <th>SĐT</th>
                    <td id="val_phone">@Model.phone</td>
                </tr>
                <tr>
                    <th>Địa chỉ</th>
                    <td id="val_address">@Model.address</td>
                </tr>
            </tbody>
        </table>

        <div class="mt-3">
            <button id="btnEdit" class="btn btn-warning">Chỉnh sửa</button>
            <button id="btnSave" class="btn btn-primary ml-2" style="display:none;">Xác nhận</button>
        </div>



        <input type="hidden" id="user_id" value="@Model.user_id" />
    </div>


    <!-- =============================== -->
    <!-- TAB 2 – BẢO MẬT -->
    <!-- =============================== -->
    <div id="contentSecurity" style="display:none;">
        <h4 style="text-align:center; margin-bottom:15px;">Đổi mật khẩu</h4>

        <table class="profile-table">
            <tr>
                <th>Mật khẩu cũ</th>
                <td><input id="old_pass" type="password" class="form-control" /></td>
            </tr>
            <tr>
                <th>Mật khẩu mới</th>
                <td><input id="new_pass" type="password" class="form-control" /></td>
            </tr>
            <tr>
                <th>Nhập lại mật khẩu mới</th>
                <td><input id="renew_pass" type="password" class="form-control" /></td>
            </tr>
        </table>

        <button id="btnConfirmChangePass" class="btn btn-primary mt-2">
            Xác nhận
        </button>
    </div>

</div>

<div class="history-btn-wrapper" style="max-width: 700px; margin: 20px auto 0 auto;">
    <button onclick="window.location.href='/QLHoso/OrderHistory'"
            class="btn btn-light d-flex justify-content-between align-items-center w-100"
            style="padding: 12px 16px; font-size: 16px; border-radius: 8px; border: 1px solid #ddd;">

        <span style="display: flex; align-items: center; gap: 8px;">
            <i class="bi bi-box-seam"></i>
            Lịch sử mua hàng
        </span>

        <i class="bi bi-chevron-right" style="font-size: 18px;"></i>
    </button>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">



<!-- =============================== -->
<!-- LỊCH SỬ MUA HÀNG -->
<!-- =============================== -->





<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    //CHUYỂN TAB


    $("#tabAccount").click(function () {
        $(".profile-tab").removeClass("tab-active");
        $(this).addClass("tab-active");

        $("#contentAccount").show();
        $("#contentSecurity").hide();
    });

    $("#tabSecurity").click(function () {
        $(".profile-tab").removeClass("tab-active");
        $(this).addClass("tab-active");

        $("#contentAccount").hide();
        $("#contentSecurity").show();
    });



    //CHỈNH SỬA THÔNG TIN TÀI KHOẢN

    $("#btnEdit").click(function () {
        $("#btnEdit").attr("disabled", true);

        $("#val_full_name").html(`<input id="edit_full_name" class="form-control edit-mode" value="${$("#val_full_name").text().trim()}"/>`);
        $("#val_email").html(`<input id="edit_email" class="form-control edit-mode" value="${$("#val_email").text().trim()}"/>`);
        $("#val_phone").html(`<input id="edit_phone" class="form-control edit-mode" value="${$("#val_phone").text().trim()}"/>`);
        $("#val_address").html(`<input id="edit_address" class="form-control edit-mode" value="${$("#val_address").text().trim()}"/>`);

        $("#btnSave").show();
    });

    $("#btnSave").click(function () {
        $.ajax({
            url: '/QLHoso/Update',
            type: 'POST',
            data: {
                user_id: $("#user_id").val(),
                full_name: $("#edit_full_name").val(),
                email: $("#edit_email").val(),
                phone: $("#edit_phone").val(),
                address: $("#edit_address").val()
            },
            success: function (res) {
                if (res.success) {

                    $("#val_full_name").text(res.data.full_name);
                    $("#val_email").text(res.data.email);
                    $("#val_phone").text(res.data.phone);
                    $("#val_address").text(res.data.address);

                    alert("Cập nhật thành công!");

                    $("#btnSave").hide();
                    $("#btnEdit").attr("disabled", false);
                }
                else alert(res.message);
            }
        });
    });



    //ĐỔI MẬT KHẨU

    $("#btnConfirmChangePass").click(function () {

        let oldPass = $("#old_pass").val();
        let newPass = $("#new_pass").val();
        let reNewPass = $("#renew_pass").val();
        let userId = $("#user_id").val();

        $.ajax({
            url: '/QLHoso/ChangePassword',
            type: 'POST',
            data: {
                userId: userId,
                oldPass: oldPass,
                newPass: newPass,
                reNewPass: reNewPass
            },
            success: function (res) {
                alert(res.message);

                if (res.success) {
                    // Thành công: làm rỗng input
                    $("#old_pass").val("");
                    $("#new_pass").val("");
                    $("#renew_pass").val("");
                } else {
                    // Lỗi: cũng làm rỗng input
                    $("#old_pass").val("");
                    $("#new_pass").val("");
                    $("#renew_pass").val("");
                }
            },
            error: function () {
                alert("Lỗi server!");
            }
        });
    });
</script>
