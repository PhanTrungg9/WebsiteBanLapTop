
@model IEnumerable<WebBanLapTop.Models.vw_OrderDetailList>
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<h2 style="margin-top: 20px; text-align: center;">Chi tiết đơn hàng</h2>

<div class="order-detail-wrapper">
    <table id="orderDetailTable" class="profile-table">
        <thead>
            <tr>
                <th>Hình ảnh</th>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Giá tiền</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="width: 120px;">
                        <img src="@item.ProductImage"
                             style="width: 90px; height: 90px; object-fit: cover; border-radius: 6px;" />
                    </td>

                    <td>@item.ProductName</td>

                    <td>@item.quantity</td>

                    <td>@((item.ProductPrice ?? 0).ToString("N0")) VND</td>

                </tr>
            }

            <!-- HÀNG TỔNG TIỀN -->
            <tr class="total-row">
                <td colspan="4">
                    Tổng tiền: @String.Format("{0:N0} VND", Model.First().total_amount)
                </td>
            </tr>
        </tbody>
    </table>
</div>

<style>

    .order-detail-wrapper {
        width: 70%;
        margin: 0 auto;
    }

    #orderDetailTable {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

        #orderDetailTable th,
        #orderDetailTable td {
            text-align: center;
            vertical-align: middle;
            padding: 10px;
            border: 1px solid #e6e6e6;
        }

        #orderDetailTable th {
            background: #2c3e50;
            color: #fff;
        }

        #orderDetailTable tbody tr:nth-child(even) {
            background: #fafafa;
        }

    /* hàng tổng tiền */
    .total-row td {
        background: #ffb36b !important;
        color: white;
        font-size: 17px;
        font-weight: 700;
        text-align: right !important;
        padding-right: 25px !important;
    }
</style>
