@model WebBanLapTop.Models.tb_user
@*@{
    ViewBag.Title = "Thanh toán";
}*@
<body>
    <form id="form-action">
        <h3>Thông tin khách hàng</h3>

        @if (Model == null)
        {
            <div class="form-group">
                <label>Họ tên khách hàng <span class="text-danger">*</span></label>
                <input type="text" name="CustomerName" id="CustomerName" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-CustomerName"></span>
            </div>
            <div class="form-group">
                <label>Số điện thoại <span class="text-danger">*</span></label>
                <input type="text" name="Phone" id="Phone" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-Phone"></span>
            </div>
            <div class="form-group">
                <label>Địa chỉ <span class="text-danger">*</span></label>
                <input type="text" name="Address" id="Address" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-Address"></span>
            </div>
            <div class="form-group">
                <label>Email <span class="text-danger">*</span></label>
                <input type="email" name="Email" id="Email" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-Email"></span>
            </div>
        }
        else
        {
            <div class="form-group">
                <label>Họ tên khách hàng <span class="text-danger">*</span></label>
                <input type="text" name="CustomerName" id="CustomerName" value="@Model.full_name" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-CustomerName"></span>
            </div>
            <div class="form-group">
                <label>Số điện thoại <span class="text-danger">*</span></label>
                <input type="text" name="Phone" id="Phone" value="@Model.phone" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-Phone"></span>
            </div>
            <div class="form-group">
                <label>Địa chỉ <span class="text-danger">*</span></label>
                <input type="text" name="Address" id="Address" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-Address"></span>
            </div>
            <div class="form-group">
                <label>Email <span class="text-danger">*</span></label>
                <input type="email" name="Email" id="Email" value="@Model.email" class="form-control" autocomplete="off" />
                <span class="error-message" id="error-Email"></span>
            </div>
        }

        <div class="form-group">
            <label>Hình thức thanh toán</label>
            <select class="form-control" name="TypePayment" id="drTypePayment">
                <option value="1" selected>Tiền mặt</option>
                <option value="2">Chuyển khoản</option>
            </select>
        </div>

        <div class="form-group" id="load_form_payment" style="display:none;">
            <h4><label>Chọn phương thức thanh toán:</label><br /></h4>
            <h5>Cách 1: Chuyển hướng sang VNPAY chọn phương thức thanh toán</h5>
            <label><input type="radio" name="TypePaymentVN" value="0" checked /> Cổng thanh toán VNPAYQR </label>
            <h5>Cách 2: Tách phương thức thanh toán tại site của Chúng tôi</h5>
            <label><input type="radio" name="TypePaymentVN" value="1" /> Thanh toán qua ứng dụng hỗ trợ VNPAYQR </label><br />
            <label><input type="radio" name="TypePaymentVN" value="2" /> ATM-Tài khoản ngân hàng nội địa </label><br />
            <label><input type="radio" name="TypePaymentVN" value="3" /> Thanh toán qua thẻ quốc tế </label><br />
        </div>

        <div class="form-group" id="load_send"></div>

        <div class="form-group mt-5">
            <button type="submit" class="btn btn-block btn-success btnCheckOut" id="btnCheckOut" style="width:100%;">Đặt hàng</button>
        </div>
    </form>
</body>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Hiển thị/ẩn form thanh toán VNPAY
        $('#drTypePayment').change(function () {
            if ($(this).val() == '2') {
                $('#load_form_payment').show();
            } else {
                $('#load_form_payment').hide();
            }
        });

        // Hàm xóa tất cả lỗi
        function clearAllErrors() {
            $('.error-message').text('').hide();
            $('.form-control').removeClass('is-invalid');
        }

        // Hàm hiển thị lỗi cho từng trường
        function showError(fieldId, message) {
            $('#' + fieldId).addClass('is-invalid');
            $('#error-' + fieldId).text(message).show();
        }

        // Validate từng trường khi người dùng rời khỏi input (blur)
        $('#CustomerName').blur(function() {
            var value = $(this).val().trim();
            $('#error-CustomerName').text('').hide();
            $(this).removeClass('is-invalid');

            if (value === '') {
                showError('CustomerName', 'Vui lòng nhập họ tên khách hàng');
            }
        });

        $('#Phone').blur(function() {
            var value = $(this).val().trim();
            $('#error-Phone').text('').hide();
            $(this).removeClass('is-invalid');

            if (value === '') {
                showError('Phone', 'Vui lòng nhập số điện thoại');
            } else if (!/^[0-9]{10,11}$/.test(value)) {
                showError('Phone', 'Số điện thoại không hợp lệ (phải có 10-11 chữ số)');
            }
        });

        $('#Address').blur(function() {
            var value = $(this).val().trim();
            $('#error-Address').text('').hide();
            $(this).removeClass('is-invalid');

            if (value === '') {
                showError('Address', 'Vui lòng nhập địa chỉ');
            }
        });

        $('#Email').blur(function() {
            var value = $(this).val().trim();
            $('#error-Email').text('').hide();
            $(this).removeClass('is-invalid');

            if (value === '') {
                showError('Email', 'Vui lòng nhập email');
            }
        });

        // Hàm validate toàn bộ form
        function validateForm() {
            var isValid = true;
            clearAllErrors();

            // Kiểm tra họ tên
            var customerName = $('#CustomerName').val().trim();
            if (customerName === '') {
                showError('CustomerName', 'Vui lòng nhập họ tên khách hàng');
                isValid = false;
            }

            // Kiểm tra số điện thoại
            var phone = $('#Phone').val().trim();
            if (phone === '') {
                showError('Phone', 'Vui lòng nhập số điện thoại');
                isValid = false;
            } else if (!/^[0-9]{10,11}$/.test(phone)) {
                showError('Phone', 'Số điện thoại không hợp lệ (phải có 10-11 chữ số)');
                isValid = false;
            }

            // Kiểm tra địa chỉ
            var address = $('#Address').val().trim();
            if (address === '') {
                showError('Address', 'Vui lòng nhập địa chỉ');
                isValid = false;
            }

            // Kiểm tra email
            var email = $('#Email').val().trim();
            if (email === '') {
                showError('Email', 'Vui lòng nhập email');
                isValid = false;
            } 
            return isValid;
        }

        // Xử lý submit form
        $('.btnCheckOut').on('click', function (e) {
            e.preventDefault();

            // Validate form
            if (!validateForm()) {
                // Cuộn đến trường lỗi đầu tiên
                var firstError = $('.is-invalid').first();
                if (firstError.length) {
                    $('html, body').animate({
                        scrollTop: firstError.offset().top - 100
                    }, 500);
                }
                return false;
            }

            var form = $('#form-action')[0];
            var formData = new FormData(form);

            var conf = confirm('Bạn chắc chắn sẽ thanh toán?');
            if (conf == true) {
                $(this).prop('disabled', true).text('Đang xử lý...');
                $.ajax({
                    url: '/ShoppingCart/Payment',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (rs) {
                        if (rs.Success) {
                            if (rs.Code == 1) {
                                location.href = "/ShoppingCart/CheckOutSuccess";

                            }
                            else {
                                location.href = rs.Url;
                            }
                        }
                    },
                    error: function (xhr, status, error) {
                        alert('Có lỗi xảy ra: ' + error);
                        console.log(xhr.responseText);
                        $('.btnCheckOut').prop('disabled', false).text('Đặt hàng');
                    }
                });
            } else {
                // Nếu user hủy confirm, enable lại button
                $(this).prop('disabled', false);
            }
        });
    });
</script>
<style>
    .text-danger {
        color: red;
        font-weight: bold;
    }

    .error-message {
        display: none;
        color: #dc3545;
        font-size: 14px;
        margin-top: 5px;
        font-weight: 500;
    }

    .form-control.is-invalid {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
    }

    .form-group {
        margin-bottom: 20px;
    }
</style>