
@{
    ViewBag.Title = "Them";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <!-- Left navbar links -->
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/category" class="nav-link">Danh mục</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Thêm mới</a>
        </li>
    </ul>
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Thêm mới danh mục</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Danh mục</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<section class="content">
    <div class="card">
        <div class="card-body">
            <div class="form-group">
                <label>Mã danh mục </label>
                <input type="text" class="form-control" id="txt_categoryid" name="txt_categoryid" />
            </div>

            <div class="form-group">
                <label>Danh mục Laptop</label>
                <input type="text" class="form-control" id="txt_name" name="txt_name" />
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <input type="text" class="form-control" id="txt_description" name="txt_description" />
            </div>

            <div class="form-group">
                <a href="/Admin/QLDMSP/DanhMucSanPham" class="btn btn-danger">Quay lại</a>
                <button type="button" id="btn_them" class="btn btn-primary">Thêm</button>
            </div>
        </div>
    </div>
</section>

@section scripts{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $("#btn_them").click(function () {

            // Lấy dữ liệu trực tiếp từ input
            var data = {
                txt_categoryid: $("#txt_categoryid").val(),
                txt_name: $("#txt_name").val(),
                txt_description: $("#txt_description").val()
            };

            $.ajax({
                type: "POST",
                url: "/Admin/QLDMSP/Insert",
                data: data,
                success: function (response) {
                    alert(response); // Hiện thông báo từ Controller
                    // Nếu muốn quay lại danh sách sau khi thêm thành công
                    if (response.includes("thành công")) {
                        window.location.href = "/Admin/QLDMSP/DanhMucSanPham";
                    }
                },
                error: function () {
                    alert("Có lỗi xảy ra khi thêm danh mục!");
                }
            });
        });
    </script>
}
