@model WebBanLapTop.Models.tb_category
@{
    ViewBag.Title = "Sua";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <!-- Left navbar links -->
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/category" class="nav-link">Danh mục</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Thêm mới</a>
        </li>
    </ul>
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Chỉnh sửa danh mục</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Danh mục</a></li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<section class="content">
    <div class="card">
        <div class="card-body">
            <div class="form-group">
                <label>Mã danh mục </label>
                <input type="text" class="form-control" id="txt_categoryid" name="txt_categoryid" />
            </div>

            <div class="form-group">
                <label>Tên danh mục</label>
                <input type="text" class="form-control" id="txt_name" name="txt_name" />
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <input type="text" class="form-control" id="txt_description" name="txt_description" />
            </div>

            <div class="form-group">
                <a href="/Admin/QLDMSP/DanhMucSanPham" class="btn btn-danger">Quay lại</a>
                <button type="button" id="btn_capnhat" class="btn btn-primary">Cập nhật</button>
            </div>
        </div>
    </div>
</section>
@section scripts{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            var urlParts = window.location.pathname.split('/');
            var categoryId = urlParts[urlParts.length - 1]; 
            if (isNaN(categoryId) || categoryId === "") {
                //console.error("Mã danh mục không hợp lệ:", categoryId);
                return;
            }

            $.ajax({
                url: '/Admin/QLDMSP/LayTTDM',
                type: 'GET',
                data: { id: categoryId },
                success: function (response) {
                    try {
                        var data = JSON.parse(response);
                        $("#txt_categoryid").val(data.category_id).prop("readonly", true);
                        $("#txt_name").val(data.name);
                        $("#txt_description").val(data.description);
                    } catch (e) {
                        alert(response);
                    }
                },
                error: function (xhr) {
                    alert("Không thể tải dữ liệu (mã lỗi " + xhr.status + ")");
                }
            });
        });
        $("#btn_capnhat").click(function () {
            var id = $("#txt_categoryid").val();
            var name = $("#txt_name").val();
            var description = $("#txt_description").val();
            if (!name || name.trim() === '') {
                Swal.fire({
                    icon: 'warning',
                    title: 'Thiếu thông tin',
                    text: 'Vui lòng nhập tên danh mục!',
                    confirmButtonText: 'Đóng'
                });
                return;
            }
            Swal.fire({
                title: 'Xác nhận cập nhật',
                text: "Bạn có chắc chắn muốn cập nhật danh mục này?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Cập nhật',
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {

                    $.ajax({
                        url: '/Admin/QLDMSP/CapNhat',
                        type: 'POST',
                        data: {
                            category_id: id,
                            name: name,
                            description: description
                        },
                        dataType: 'json',
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công!',
                                    text: res.message || 'Cập nhật danh mục thành công!',
                                    showConfirmButton: false,
                                    timer: 1500,
                                    timerProgressBar: true
                                }).then(() => {
                                    window.location.href = '/Admin/QLDMSP/DanhMucSanPham';
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi!',
                                    text: res.message || 'Cập nhật danh mục thất bại!',
                                    confirmButtonText: 'Đóng',
                                    confirmButtonColor: '#d33'
                                });
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Oops...',
                                text: 'Không thể gửi yêu cầu đến server!',
                                footer: '<small>Vui lòng kiểm tra kết nối và thử lại</small>',
                                confirmButtonText: 'Đóng',
                                confirmButtonColor: '#d33'
                            });
                        }
                    });
                }
            });
        });
    </script>
}
