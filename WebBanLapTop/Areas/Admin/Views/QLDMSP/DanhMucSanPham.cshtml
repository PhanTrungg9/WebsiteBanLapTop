@model IEnumerable<WebBanLapTop.Models.tb_category>
@{
    ViewBag.Title = "DanhMucSanPham";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="~/Content/Admin/index3.html" class="nav-link">Home</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Danh mục sản phẩm</a>
        </li>
    </ul>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Quản lý danh mục sản phẩm</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">Quản lý danh mục sản phẩm</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Main content -->
<section class="content">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Danh mục sản phẩm</h3>

            <div class="card-tools">
                <a href="@Url.Action("Them", "QLDMSP", new { area = "Admin" })" class="btn btn-info">Thêm mới</a>
            </div>
        </div>

        <div class="card-body">
            <div class="col-sm-12">
                <table id="tb_show" class="table table-bordered">
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Mã danh mục</th>
                            <th>Danh mục Laptop</th>
                            <th>Mô tả</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var index = (ViewBag.Page - 1) * ViewBag.PageSize + 1;
                            foreach (var item in Model)
                            {
                                <tr id="trow_@item.category_id">
                                    <td>@index</td>
                                    <td>@item.category_id</td>
                                    <td>@item.name</td>
                                    <td>@item.description</td>
                                    <td>
                                        <a href="/Admin/QLDMSP/Sua/@item.category_id" class="btn btn-sm btn-primary">Sửa</a>
                                        <a href="#" data-id="@item.category_id" class="btn btn-sm btn-danger btnDelete">Xóa</a>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">Không có bản ghi nào</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- PHÂN TRANG -->
                <div class="mt-3">
                    <nav>
                        <ul class="pagination">
                            @if (ViewBag.Page > 1)
                            {
                                <li class="page-item">
                                    <a href="?page=@(ViewBag.Page - 1)" class="page-link">«</a>
                                </li>
                            }

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                if (i == ViewBag.Page)
                                {
                                    <li class="page-item active">
                                        <a class="page-link">@i</a>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a href="?page=@i" class="page-link">@i</a>
                                    </li>
                                }
                            }

                            @if (ViewBag.Page < ViewBag.TotalPages)
                            {
                                <li class="page-item">
                                    <a href="?page=@(ViewBag.Page + 1)" class="page-link">»</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>

            </div>
        </div>
    </div>
</section>

@section scripts{
    <script>
        $(".btnDelete").click(function () {
            if (confirm("Bạn có chắc chắn muốn xóa danh mục này không?")) {
                var id = $(this).data("id");

                $.ajax({
                    url: window.location.origin + '/Admin/QLDMSP/Delete',
                    type: 'POST',
                    data: { id: id },
                    success: function (response) {
                        alert(response);
                        location.reload(); // reload lại danh sách sau khi xoá
                    },
                    error: function () {
                        alert("Đã xảy ra lỗi khi gửi yêu cầu!");
                    }
                });
            }
        });
    </script>
}