
@{
    ViewBag.Title = "test";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
@using PagedList;
@using PagedList.Mvc;
@model IPagedList<WebBanLapTop.Models.vw_ProductWithDiscountCount>
@{
    ViewBag.Title = "Danh Sách Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="~/Content/Admin/index3.html" class="nav-link">Home</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Sản Phẩm</a>
        </li>
    </ul>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Quản lý Sản Phẩm</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">Sản Phẩm</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="row">
        <!-- Card Product (Bên trái) -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Danh Sách Sản Phẩm</h3>
                    <div class="card-tools">
                        <a href="Add" class="btn btn-info btn-sm">
                            <i class="fas fa-plus"></i> Thêm mới
                        </a>
                        <a href="#" id="btndelete" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash"></i> Xóa
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="product-list-container">
                        @if (Model != null && Model.Any())
                        {
                            var index = (ViewBag.Page - 1) * ViewBag.PageSize + 1;
                            foreach (var item in Model)
                            {
                                <div class="product-item" data-product-id="@item.product_id" onclick="selectProduct(@item.product_id, '@item.name')">
                                    <div class="product-checkbox">
                                        <input type="checkbox" class="checkitem" value="@item.product_id" onclick="event.stopPropagation()" />
                                    </div>
                                    <div class="product-image">
                                        @if (!string.IsNullOrEmpty(item.image))
                                        {
                                            <img src="@item.image" alt="@item.name" />
                                        }
                                        else
                                        {
                                            <div class="no-image">
                                                <i class="fas fa-image"></i>
                                            </div>
                                        }
                                    </div>
                                    <div class="product-info">
                                        <h5 class="product-name">@item.name</h5>
                                        <div class="product-meta">
                                            <span class="product-price">@(item.final_price.HasValue ? item.final_price.Value.ToString("N0") : "0") ₫</span>
                                            <span class="product-quantity">SL: @item.quantity</span>
                                        </div>
                                        <div class="product-discount-info">
                                            @if (item.discount_count > 0)
                                            {
                                                <span class="discount-badge">
                                                    <i class="fas fa-tag"></i> @item.discount_count đợt giảm giá
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="no-discount-text">
                                                    <i class="fas fa-minus-circle"></i> Chưa có giảm giá
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    <div class="product-actions">
                                        <a href="/admin/products/edit/@item.product_id" class="btn btn-primary btn-sm" onclick="event.stopPropagation()">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="#" data-id="@item.product_id" class="btn btn-danger btn-sm btnDelete" onclick="event.stopPropagation()">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                                index++;
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="fas fa-box-open"></i>
                                <p>Không có sản phẩm nào</p>
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="row align-items-center">
                            <div class="col-6">
                                <small class="text-muted">
                                    Hiển thị @((ViewBag.Page - 1) * ViewBag.PageSize + 1)
                                    đến @(Math.Min(ViewBag.Page * ViewBag.PageSize, Model.TotalItemCount))
                                    / @Model.TotalItemCount
                                </small>
                            </div>
                            <div class="col-6 d-flex justify-content-end">
                                @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
                                {
                                    UlElementClasses = new[] { "pagination", "pagination-sm", "m-0" },
                                    LiElementClasses = new[] { "page-item" },
                                })
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card Discount (Bên phải) -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-percent text-success"></i>
                        Đợt Giảm Giá
                    </h3>
                    <div class="card-tools">
                        <button onclick="toggleShowAddDiscount()" class="btn btn-success btn-sm">
                            <i class="fas fa-plus"></i> Thêm giảm giá
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Form thêm giảm giá -->
                    <div id="addDiscount" class="discount-form d-none mb-4">
                        <div class="form-container">
                            <div class="form-group">
                                <label>Sản phẩm</label>
                                <select id="product_name" class="form-control select2">
                                    <option value=""></option>
                                </select>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Hình thức giảm</label>
                                        <select id="discountType" class="form-control">
                                            <option value="0">Phần trăm (%)</option>
                                            <option value="1">Số tiền cố định (₫)</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Giá trị giảm</label>
                                        <input type="number" id="discountValue" class="form-control" placeholder="Nhập giá trị" min="0" />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Ngày bắt đầu</label>
                                        <input type="date" id="startDate" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Ngày kết thúc</label>
                                        <input type="date" id="endDate" class="form-control" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Mô tả</label>
                                <input type="text" id="description" class="form-control" placeholder="Nhập mô tả đợt giảm giá" />
                            </div>
                            <div class="text-right">
                                <button class="btn btn-secondary" onclick="toggleShowAddDiscount()">Hủy</button>
                                <button class="btn btn-success" onclick="saveDiscount()">
                                    <i class="fas fa-save"></i> Lưu
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Hiển thị sản phẩm được chọn -->
                    <div id="selectedProductInfo" class="selected-product-info d-none">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            Đang xem giảm giá của: <strong id="selectedProductName"></strong>
                        </div>
                    </div>

                    <!-- Danh sách giảm giá -->
                    <div id="discountListContainer">
                        <div class="discount-empty-state">
                            <i class="fas fa-hand-pointer"></i>
                            <p>Chọn một sản phẩm để xem đợt giảm giá</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Product List Styles */
    .product-list-container {
        max-height: 600px;
        overflow-y: auto;
    }

    .product-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        border-bottom: 1px solid #e9ecef;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .product-item:hover {
            background-color: #f8f9fa;
        }

        .product-item.selected {
            background-color: #e3f2fd;
            border-left: 4px solid #2196F3;
        }

    .product-checkbox {
        flex-shrink: 0;
    }

    .product-image {
        flex-shrink: 0;
        width: 60px;
        height: 60px;
    }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 8px;
        }

    .no-image {
        width: 60px;
        height: 60px;
        background: #f8f9fa;
        border: 1px dashed #dee2e6;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }

        .no-image i {
            color: #adb5bd;
            font-size: 24px;
        }

    .product-info {
        flex: 1;
        min-width: 0;
    }

    .product-name {
        font-size: 15px;
        font-weight: 600;
        margin: 0 0 8px 0;
        color: #2c3e50;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .product-meta {
        display: flex;
        gap: 15px;
        margin-bottom: 5px;
    }

    .product-price {
        color: #e74c3c;
        font-weight: 600;
        font-size: 14px;
    }

    .product-quantity {
        color: #6c757d;
        font-size: 13px;
    }

    .product-discount-info {
        margin-top: 5px;
    }

    .discount-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .no-discount-text {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: #6c757d;
        font-size: 11px;
        font-style: italic;
    }

    .product-actions {
        display: flex;
        gap: 5px;
        flex-shrink: 0;
    }

    /* Discount Form Styles */
    .discount-form {
        animation: slideDown 0.3s ease;
    }

    .form-container {
        background: #f0f9ff;
        padding: 20px;
        border-radius: 10px;
        border: 1px solid #bee3f8;
    }

    .selected-product-info {
        margin-bottom: 20px;
    }

    /* Discount List Styles */
    .discount-empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #6c757d;
    }

        .discount-empty-state i {
            font-size: 48px;
            color: #dee2e6;
            margin-bottom: 15px;
        }

        .discount-empty-state p {
            margin: 0;
            font-size: 14px;
        }

    .discount-item {
        background: linear-gradient(135deg, #dcfce7 0%, #f0fdf4 100%);
        border: 1px solid #86efac;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
        position: relative;
    }

        .discount-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
        }

        .discount-item.inactive {
            opacity: 0.6;
            background: linear-gradient(135deg, #f3f4f6 0%, #f9fafb 100%);
            border-color: #d1d5db;
        }

    .discount-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 10px;
    }

    .discount-percent {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: bold;
        font-size: 16px;
        box-shadow: 0 2px 6px rgba(34, 197, 94, 0.3);
    }

    .discount-item.inactive .discount-percent {
        background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
    }

    .discount-actions {
        display: flex;
        gap: 5px;
    }

    .discount-description {
        font-weight: 600;
        color: #166534;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .discount-dates {
        display: flex;
        align-items: center;
        gap: 5px;
        color: #15803d;
        font-size: 13px;
        margin-bottom: 8px;
    }

    .discount-status {
        display: inline-block;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-active {
        background: #22c55e;
        color: white;
    }

    .status-upcoming {
        background: #3b82f6;
        color: white;
    }

    .status-expired {
        background: #ef4444;
        color: white;
    }

    /* Scrollbar */
    .product-list-container::-webkit-scrollbar {
        width: 6px;
    }

    .product-list-container::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .product-list-container::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 3px;
    }

    .product-list-container::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }

    /* Animation */

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 40px 20px;
    }

        .empty-state i {
            font-size: 48px;
            color: #dee2e6;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: #6c757d;
            margin: 0;
        }
</style>

@section scripts{
    <script>
        let selectedProductId = null;

        $(document).ready(function () {
            // Initialize Select2
            $('#product_name').select2({
                placeholder: "Chọn sản phẩm",
                ajax: {
                    url: '/Admin/Products/getProductName',
                    dataType: 'json',
                    processResults: function (data) {
                        return {
                            results: $.map(data, function (item) {
                                return { id: item.product_id, text: item.name };
                            })
                        };
                    }
                }
            });

            // Select All Checkbox
            $('body').on('change', '#SelectAll', function () {
                var checkStatus = this.checked;
                $('.checkitem').prop('checked', checkStatus);
            });

            // Individual Checkbox
            $('body').on('change', '.checkitem', function () {
                var totalCheckboxes = $('.checkitem').length;
                var checkedCheckboxes = $('.checkitem:checked').length;
                $('#SelectAll').prop('checked', totalCheckboxes === checkedCheckboxes);
            });

            // Delete Single Product
            $('body').on('click', '.btnDelete', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var id = $(this).data('id');

                if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) {
                    $.ajax({
                        url: '/admin/products/delete/' + id,
                        type: 'POST',
                        success: function (result) {
                            if (result.success) {
                                $('[data-product-id="' + id + '"]').fadeOut(300, function () {
                                    $(this).remove();
                                });
                                alert('Xóa thành công!');
                                if (selectedProductId == id) {
                                    selectedProductId = null;
                                    $('#discountListContainer').html('<div class="discount-empty-state"><i class="fas fa-hand-pointer"></i><p>Chọn một sản phẩm để xem đợt giảm giá</p></div>');
                                    $('#selectedProductInfo').addClass('d-none');
                                }
                            } else {
                                alert('Xóa thất bại: ' + result.message);
                            }
                        },
                        error: function () {
                            alert('Có lỗi xảy ra!');
                        }
                    });
                }
            });

            // Delete Multiple Products
            $('#btndelete').click(function (e) {
                e.preventDefault();
                var ids = [];
                $('.checkitem:checked').each(function () {
                    ids.push($(this).val());
                });

                if (ids.length === 0) {
                    alert('Vui lòng chọn ít nhất một sản phẩm!');
                    return;
                }

                if (confirm('Bạn có chắc chắn muốn xóa ' + ids.length + ' sản phẩm?')) {
                    $.ajax({
                        url: '/admin/products/deletemultiple',
                        type: 'POST',
                        data: { ids: ids },
                        success: function (result) {
                            if (result.success) {
                                $.each(ids, function (index, id) {
                                    $('[data-product-id="' + id + '"]').fadeOut(300, function () {
                                        $(this).remove();
                                    });
                                });
                                alert('Xóa thành công!');
                            } else {
                                alert('Xóa thất bại: ' + result.message);
                            }
                        },
                        error: function () {
                            alert('Có lỗi xảy ra!');
                        }
                    });
                }
            });
        });

        // Select Product - Load Discounts
        function selectProduct(productId, productName) {
            selectedProductId = productId;

            // Highlight selected product
            $('.product-item').removeClass('selected');
            $('[data-product-id="' + productId + '"]').addClass('selected');

            // Show product info
            $('#selectedProductInfo').removeClass('d-none');
            $('#selectedProductName').text(productName);

            // Load discounts
            loadDiscounts(productId);
        }

        // Load Discounts for Product
        function loadDiscounts(productId) {
            $.ajax({
                url: '/Admin/Products/GetDiscountsByProduct',
                type: 'GET',
                data: { productId: productId },
                success: function (result) {
                    if (result.success) {
                        displayDiscounts(result.data);
                    } else {
                        $('#discountListContainer').html('<div class="alert alert-warning">Không thể tải dữ liệu giảm giá</div>');
                    }
                },
                error: function () {
                    $('#discountListContainer').html('<div class="alert alert-danger">Có lỗi xảy ra khi tải dữ liệu</div>');
                }
            });
        }

        // Display Discounts
        function displayDiscounts(discounts) {
            if (discounts.length === 0) {
                $('#discountListContainer').html('<div class="discount-empty-state"><i class="fas fa-inbox"></i><p>Chưa có đợt giảm giá nào</p></div>');
                return;
            }

            let html = '';
            discounts.forEach(function (discount) {
                const isActive = new Date(discount.start_date) <= new Date() && new Date() <= new Date(discount.end_date);
                const isUpcoming = new Date(discount.start_date) > new Date();
                const isExpired = new Date(discount.end_date) < new Date();

                let statusClass = isActive ? 'status-active' : (isUpcoming ? 'status-upcoming' : 'status-expired');
                let statusText = isActive ? 'Đang áp dụng' : (isUpcoming ? 'Sắp diễn ra' : 'Đã hết hạn');
                let itemClass = isActive ? '' : 'inactive';

                html += `
                    <div class="discount-item ${itemClass}">
                        <div class="discount-header">
                            <span class="discount-percent">
                                ${discount.is_fixed ? '-' + discount.amount.toLocaleString() + '₫' : '-' + discount.amount + '%'}
                            </span>
                            <div class="discount-actions">
                                <button class="btn btn-sm btn-warning" onclick="editDiscount(${discount.discount_id})">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="deleteDiscount(${discount.discount_id})">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="discount-description">${discount.name || 'Không có mô tả'}</div>
                        <div class="discount-dates">
                            <i class="fas fa-calendar"></i>
                            ${new Date(discount.start_date).toLocaleDateString('vi-VN')} - ${new Date(discount.end_date).toLocaleDateString('vi-VN')}
                        </div>
                        <span class="discount-status ${statusClass}">${statusText}</span>
                    </div>
                `;
            });

            $('#discountListContainer').html(html);
        }

        // Toggle Add Discount Form
        function toggleShowAddDiscount() {
            $('#addDiscount').toggleClass('d-none');
            if (!$('#addDiscount').hasClass('d-none') && selectedProductId) {
                $('#product_name').val(selectedProductId).trigger('change');
            }
        }

        // Save Discount
        function saveDiscount() {
            const data = {
                product_id: $('#product_name').val() || selectedProductId,
                is_fixed: $('#discountType').val() == '1',
                amount: $('#discountValue').val(),
                start_date: $('#startDate').val(),
                end_date: $('#endDate').val(),
                name: $('#description').val()
            };

            if (!data.product_id || !data.amount || !data.start_date || !data.end_date) {
                alert('Vui lòng điền đầy đủ thông tin!');
                return;
            }

            $.ajax({
                url: '/Admin/Products/SaveDiscount',
                type: 'POST',
                data: data,
                success: function (result) {
                    if (result.success) {
                        alert('Thêm giảm giá thành công!');
                        toggleShowAddDiscount();
                        // Reset form
                        $('#discountValue').val('');
                        $('#startDate').val('');
                        $('#endDate').val('');
                        $('#description').val('');
                        // Reload discounts if viewing this product
                        if (selectedProductId == data.product_id) {
                            loadDiscounts(selectedProductId);
                        }
                        location.reload();
                    } else {
                        alert('Thêm giảm giá thất bại: ' + result.message);
                    }
                },
                error: function () {
                    alert('Có lỗi xảy ra!');
                }
            });
        }

        // Delete Discount
        function deleteDiscount(discountId) {
            if (confirm('Bạn có chắc chắn muốn xóa đợt giảm giá này?')) {
                $.ajax({
                    url: '/Admin/Products/DeleteDiscount',
                    type: 'POST',
                    data: { discountId: discountId },
                    success: function (result) {
                        if (result.success) {
                            alert('Xóa thành công!');
                            loadDiscounts(selectedProductId);
                            location.reload();
                        } else {
                            alert('Xóa thất bại: ' + result.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra!');
                    }
                });
            }
        }

        // Edit Discount (Optional - you can implement this)
        function editDiscount(discountId) {
            alert('Tính năng chỉnh sửa đang được phát triển!');
        }
    </script>
}

