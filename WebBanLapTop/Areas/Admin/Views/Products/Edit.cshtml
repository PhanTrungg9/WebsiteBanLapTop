@model  WebBanLapTop.Models.tb_product
@{
    ViewBag.Title = "Chỉnh sửa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader {
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                <i class="fas fa-bars"></i>
            </a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="~/Content/client/index3.html" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Sản Phẩm</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Cập Nhật</a>
        </li>
    </ul>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Chỉnh sửa Sản Phẩm</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Thông Tin Chỉnh Sửa Sản Phẩm</h3>
        </div>

        <div class="card-body">
            <div class="card">
                <div class="card-header p-2">
                    <ul class="nav nav-pills">
                        <li class="nav-item">
                            <a class="nav-link active" href="#tab-info" data-toggle="tab">Thông tin sản phẩm</a>
                        </li>
                    </ul>
                </div>
                <form id="form-act">
                    <div class="card-body">
                        <div class="tab-content">
                            <div class="active tab-pane" id="tab-info">
                                <input type="hidden"  name="product_id" id="product_id"/>
                                <div class="form-group">
                                    <label for="name">Tên sản phẩm</label>
                                    <input type="text" name="name" class="form-control" placeholder="Nhập tên sản phẩm" />
                                </div>
                                <div class="form-group">
                                    <label for="category">Tên danh mục</label>
                                    <select name="category_id" id="category_id" class="form-control select2"></select>

                                </div>
                                <div class="form-group">
                                    <label for="brand">Tên nhãn hiệu</label>
                                    <select name="brand_id" id="brand_id" class="form-control select2"></select>

                                </div>
                                <div class="form-group">
                                    <label for="description">Mô tả</label>
                                    <textarea id="txtarea" name="description" class="form-control" rows="3"></textarea>
                                </div>
                                <div class="form-group">
                                    <label for="quantity">Số lượng</label>
                                    <input type="number" name="quantity" class="form-control" placeholder="Nhập số lượng" />
                                </div>
                                <div class="form-group">
                                    <label for="price">Giá bán</label>
                                    <input type="text" name="price" id="price" class="form-control" placeholder="Nhập giá bán" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer text-right">
                        <button type="button" id="btn_capnhat" class="btn btn-success">Cập nhật sản phẩm</button>
                        <a href="/admin/products" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section scripts{
    <script>
        $(document).ready(function () {
            const pathPart = window.location.pathname.split('/');
            const id = pathPart[pathPart.length - 1];
            const formdata = new FormData();
            formdata.append("id", id);

            $.ajax({
                url: '/Admin/Products/GetCategories',
                type: 'GET',
                success: function (data) {
                    const select = $('#category_id');
                    select.empty();
                    select.append('<option value="">-- Chọn danh muc --</option>');
                    $.each(data, function (i, item) {
                        select.append($('<option>', {
                            value: String(item.category_id),
                            text: item.name
                        }));
                    });
                    loadProductInfo();
                }
            });
            $.ajax({
                url: '/Admin/Products/GetBrands',
                type: 'GET',
                success: function (data) {
                    const select = $('#brand_id');
                    select.empty();
                    select.append('<option value="">-- Chọn nhãn hiệu --</option>');
                    $.each(data, function (i, item) {
                        select.append($('<option>', {
                            value: String(item.brand_id),
                            text: item.name
                        }));
                    });
                }
            });

            function loadProductInfo() {
                $.ajax({
                    type: "POST",
                    url: '/Admin/Products/LayTTSP',
                    data: formdata,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        if (response.success) {
                            $('input[name="product_id"]').val(response.data.product_id);
                            $('input[name="name"]').val(response.data.name);
                            $('select[name="category_id"]').val(response.data.category_id).trigger('change');
                            $('select[name="brand_id"]').val(response.data.brand_id).trigger('change');
                            $('textarea[name="description"]').val(response.data.description);
                            $('input[name="quantity"]').val(response.data.quantity);
                            $('#price').val(response.data.price);
                        } else {
                            alert(response.message || 'Không thể tải thông tin sản phẩm');
                        }
                    },

                })
            }
            $('#btn_capnhat').on('click', function () {
                const form = $('#form-act')[0];
                const formdata = new FormData(form);
                $.ajax({
                    type: 'POST',
                    url: '/Admin/Products/Update',
                    data: formdata,
                    processData: false,
                    contentType: false,
                    cache: false,
                    dataType: 'json', 
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: response.message || 'Cập nhật sản phẩm thành công!',
                                showConfirmButton: false,
                                timer: 1500,
                                timerProgressBar: true
                            }).then(() => {
                                $('#form-act')[0].reset();
                                window.location.href = '/Admin/Products/Index';
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi!',
                                text: response.message || 'Cập nhật sản phẩm thất bại',
                                confirmButtonText: 'Đóng',
                                confirmButtonColor: '#d33'
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Oops...',
                            text: 'Đã xảy ra lỗi trong quá trình cập nhật!',
                            footer: '<small>Vui lòng thử lại sau</small>',
                            confirmButtonText: 'Đóng',
                            confirmButtonColor: '#d33'
                        });
                    }
                });
            });

        });
    </script>
    }