@model IEnumerable<WebBanLapTop.Models.tb_user>
@{
    ViewBag.Title = "DanhSachNguoiDung";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="~/Content/Admin/index3.html" class="nav-link">Home</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Người Dùng</a>
        </li>
    </ul>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Quản lý người dùng</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">Quản lý người dùng</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<!-- Main content -->
<section class="content">

    <!-- Default box -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Danh Sách người dùng</h3>

            <div class="card-tools">
                @*<a href="#" class="btn btn-info">Thêm mới</a>*@
                <div class="d-flex align-items-center">
                    <input type="text" id="txtSearch" class="form-control mr-2" placeholder="Tìm kiếm tên hoặc email..." style="width: 250px;" />
                    <button id="btnSearch" class="btn btn-primary mr-2"><i class="fas fa-search"></i> Tìm kiếm</button>
                    <button id="btnDeleteSelected" class="btn btn-danger"> <i class="fas fa-trash"></i> Xóa </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="col-sm-12">
                <table id="tb_show" class="table table-bordered">
                    <thead>
                        <tr>
                            <th><input type="checkbox" id="SelectAll" /></th>
                            <th>STT</th>
                            <th>Họ tên</th>
                            <th>Tên đăng nhập</th>
                            <th>Mật khẩu</th>
                            <th>Email</th>
                            <th>SĐT</th>
                            <th>Địa chỉ</th>
                            <th>Trạng thái</th> <!-- Toggle tròn -->
                            <th>Phân quyền</th> <!-- Toggle vuông -->
                        </tr>
                    </thead>
                    <tbody id="userTableBody">
                        @if (Model != null && Model.Any())
                        {
                            //var index = 1;
                            var index = (ViewBag.Page - 1) * ViewBag.PageSize + 1;

                            foreach (var user in Model)
                            {
                                <tr id="trow_@user.user_id">
                                    <td><input type="checkbox" class="checkuser" value="@user.user_id" /></td>
                                    <td>@index</td>
                                    <td>@user.full_name</td>
                                    <td>@user.user_name</td>
                                    <td>@user.password</td>
                                    <td>@user.email</td>
                                    <td>@user.phone</td>
                                    <td>@user.address</td>

                                    <!-- Cột toggle tròn: khóa / mở khóa -->
                                    <td class="text-center">
                                        <label class="toggle-round">
                                            <input type="checkbox"
                                                   class="toggle-active"
                                                   data-id="@user.user_id"
                                                   @( (user.is_active ?? false) ? "checked" : "" ) />
                                            <span class="slider"></span>
                                        </label>
                                    </td>

                                    <!-- Cột toggle vuông: phân quyền -->
                                    <td class="text-center">
                                        <label class="toggle-square">
                                            <input type="checkbox"
                                                   class="toggle-role"
                                                   data-id="@user.user_id"
                                                   @( (user.usertype ?? false) ? "checked" : "" ) />
                                            <span class="slider"></span>
                                        </label>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center">Không có bản ghi nào</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="mt-3">
                    <nav>
                        <ul class="pagination d-flex justify-content-end" id="mainPagination">
                            @if (ViewBag.Page > 1)
                            {
                                <li class="page-item">
                                    <a href="javascript:void(0)" onclick="goToPage(@(ViewBag.Page - 1))" class="page-link">«</a>
                                </li>
                            }

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                if (i == ViewBag.Page)
                                {
                                    <li class="page-item active">
                                        <a href="javascript:void(0)" class="page-link">@i</a>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a href="javascript:void(0)" onclick="goToPage(@i)" class="page-link">@i</a>
                                    </li>
                                }
                            }

                            @if (ViewBag.Page < ViewBag.TotalPages)
                            {
                                <li class="page-item">
                                    <a href="javascript:void(0)" onclick="goToPage(@(ViewBag.Page + 1))" class="page-link">»</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>

            </div>
            <!-- /.card-footer-->
        </div>
        <!-- /.card -->
    </div>
</section>

<style>
    .toggle-round {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

        .toggle-round input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-round .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 34px;
        }

            .toggle-round .slider:before {
                position: absolute;
                content: "";
                height: 20px;
                width: 20px;
                left: 3px;
                bottom: 3px;
                background-color: white;
                transition: .4s;
                border-radius: 50%;
            }

        .toggle-round input:checked + .slider {
            background-color: #2196F3;
        }

            .toggle-round input:checked + .slider:before {
                transform: translateX(24px);
            }

 
    .toggle-square {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

        .toggle-square input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-square .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 4px;
        }

            .toggle-square .slider:before {
                position: absolute;
                content: "";
                height: 18px;
                width: 18px;
                left: 4px;
                bottom: 4px;
                background-color: white;
                transition: .4s;
                border-radius: 2px;
            }

        .toggle-square input:checked + .slider {
            background-color: #007bff;
        }

            .toggle-square input:checked + .slider:before {
                transform: translateX(22px);
            }
</style>
@section scripts{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        var currentKeyword = ""; // Lưu keyword hiện tại

        $("#SelectAll").click(function () {
            $(".checkuser").prop("checked", this.checked);
        });

        //$(document).on("click", ".btnDelete", function (e) {
        //    e.preventDefault();
        //    var id = $(this).data("id");
        //    if (confirm("Bạn có chắc chắn muốn xóa người dùng này không?")) {
        //        $.ajax({
        //            url: '/Admin/QLND/Delete',
        //            type: 'POST',
        //            data: { id: id },
        //            success: function (res) {
        //                if (res.success) {
        //                    $("#trow_" + id).remove();
        //                    alert("Đã xóa thành công!");
        //                } else {
        //                    alert(res.message || "Xóa thất bại!");
        //                }
        //            },
        //            error: function () {
        //                alert("Không thể gửi yêu cầu xóa đến server!");
        //            }
        //        });
        //    }
        //});

        $("#btnDeleteSelected").click(function () {
            var selectedIds = $(".checkuser:checked").map(function () {
                return $(this).val();
            }).get();

            if (selectedIds.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Chưa chọn người dùng',
                    text: 'Vui lòng chọn ít nhất 1 người dùng để xóa!',
                    confirmButtonText: 'Đóng'
                });
                return;
            }

            Swal.fire({
                title: 'Bạn có chắc chắn?',
                text: `Bạn đang xóa ${selectedIds.length} người dùng. Không thể hoàn tác!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: `Xóa ${selectedIds.length} người`,
                cancelButtonText: 'Hủy',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Admin/QLND/DeleteMulti',
                        type: 'POST',
                        traditional: true,
                        data: { ids: selectedIds },
                        dataType: 'json',
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Đã xóa!',
                                    text: `Đã xóa thành công ${selectedIds.length} người dùng.`,
                                    showConfirmButton: false,
                                    timer: 1500,
                                    timerProgressBar: true
                                }).then(() => {
                                    selectedIds.forEach(id => {
                                        $("#trow_" + id).fadeOut(400, function () {
                                            $(this).remove();
                                        });
                                    });

                                    setTimeout(() => {
                                        if (currentKeyword) {
                                            goToPage(1);
                                        } else {
                                            location.reload();
                                        }
                                    }, 500);
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi!',
                                    text: res.message || 'Có lỗi xảy ra khi xóa!',
                                    confirmButtonText: 'Đóng'
                                });
                            }
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: 'Không thể gửi yêu cầu xóa nhiều!',
                                confirmButtonText: 'Đóng'
                            });
                        }
                    });
                }
            });
        });

        // Hàm tìm kiếm
        $('#btnSearch').click(function () {
            currentKeyword = $('#txtSearch').val().trim();
            goToPage(1); // Bắt đầu từ trang 1 khi tìm kiếm mới
        });

        // Enter để tìm kiếm
        $('#txtSearch').keypress(function (e) {
            if (e.which === 13) {
                $('#btnSearch').click();
            }
        });

        // Hàm chuyển trang - HÀM QUAN TRỌNG NHẤT
        function goToPage(page) {
            var keyword = $('#txtSearch').val().trim();
            currentKeyword = keyword;

            if (keyword !== "") {
                // Ẩn phân trang chính khi đang tìm kiếm
                $('#mainPagination').parent().hide();

                $.ajax({
                    url: '/Admin/QLND/SearchUser',
                    type: 'GET',
                    data: { keyword: keyword, page: page },
                    success: function (data) {
                        $('#userTableBody').html(data);
                        $('#SelectAll').prop('checked', false);
                    },
                    error: function () {
                        alert('Lỗi khi tìm kiếm người dùng!');
                    }
                });
            } else {
                // Hiện lại phân trang chính khi không tìm kiếm
                $('#mainPagination').parent().show();
                window.location.href = '/Admin/QLND/DanhSachNguoiDung?page=' + page;
            }
        }

        // Toggle mở khóa / khóa tài khoản
        $(document).on('change', '.toggle-active', function () {
            var id = $(this).data('id');
            var isActive = $(this).is(':checked');

            $.ajax({
                url: '/Admin/QLND/ToggleActive',
                type: 'POST',
                data: { id: id, isActive: isActive },
                success: function (res) {
                    if (res.success) {
                        alert(isActive ? "Tài khoản đã được mở khóa!" : "Tài khoản đã bị khóa!");
                    } else {
                        alert(res.message || "Cập nhật trạng thái thất bại!");
                    }
                },
                error: function () {
                    alert("Không thể gửi yêu cầu đến server!");
                }
            });
        });

        // Toggle phân quyền Admin / User
        $(document).on('change', '.toggle-role', function () {
            var id = $(this).data('id');
            var isAdmin = $(this).is(':checked');

            $.ajax({
                url: '/Admin/QLND/ToggleRole',
                type: 'POST',
                data: { id: id, isAdmin: isAdmin },
                success: function (res) {
                    if (res.success) {
                        alert(isAdmin ? "Tài khoản đã được cấp quyền Admin!" : "Đã chuyển về quyền User!");
                    } else {
                        alert(res.message || "Cập nhật quyền thất bại!");
                    }
                },
                error: function () {
                    alert("Không thể gửi yêu cầu đến server!");
                }
            });
        });

    </script>
}

